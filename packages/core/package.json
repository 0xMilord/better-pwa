{
  "name": "@better-pwa/core",
  "version": "1.0.1",
  "description": "Zero-dependency PWA runtime: state engine, lifecycle bus, permissions, and updates",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --minify",
    "test": "vitest run --coverage",
    "lint": "eslint src/ --fix",
    "docs:generate": "typedoc --plugin typedoc-plugin-markdown --entryPointStrategy expand --out ../../docs/src/content/api @better-pwa/core"
  },
  "dependencies": {
    "@better-logger/core": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "tsup": "^8.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}